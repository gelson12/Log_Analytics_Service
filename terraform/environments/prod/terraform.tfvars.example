# terraform/environments/prod/terraform.tfvars.example
#
# Copy to terraform.tfvars (git-ignored) and fill in your values,
# or pass each as -var="..." on the CLI / via GitHub Actions secrets.

aws_region  = "eu-west-1"
environment = "prod"

# Your existing VPC and subnets
vpc_id             = "vpc-0123456789abcdef0"
public_subnet_ids  = ["subnet-aaaa1111", "subnet-bbbb2222"]
private_subnet_ids = ["subnet-cccc3333", "subnet-dddd4444"]

# S3 buckets the service may read logs from.
# The task role will get s3:ListBucket + s3:GetObject ONLY on these buckets.
log_buckets = ["my-log-bucket", "my-other-log-bucket"]

# Set by CI/CD to the short git SHA; override locally for manual deploys.
image_tag = "latest"
